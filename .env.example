# 环境变量配置示例

# 服务器配置
PORT=3001
NODE_ENV=development

# 数据库配置
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=todo_platform
DATABASE_USER=root
DATABASE_PASSWORD=your_password_here

# JWT 配置
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=24h

# CORS 配置
CORS_ORIGIN=http://localhost:3457

# AI 配置（阿里云百炼）
ALIYUN_API_KEY=your_api_key_here
ALIYUN_MODEL=qwen3.5-plus

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/app.log
